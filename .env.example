# Optional external API keys. Copy to .env.local and fill only the services you want to test.

# Brave Search API
BRAVE_API_KEY=

# Tavily Search API
TAVILY_API_KEY=

# Massive / Polygon market data API
MASSIVE_API_KEY=
# POLYGON_API_KEY= also works as an alias.

# ExchangeRate-API, https://www.exchangerate-api.com
EXCHANGERATE_API_KEY=

# Exchangeratesapi.io / APILayer, https://exchangeratesapi.io
EXCHANGERATESAPI_IO_KEY=

# Perplexity Sonar API
PERPLEXITY_API_KEY=

# Alpha Vantage API
ALPHA_VANTAGE_API_KEY=

# Finlight financial news API
FINLIGHT_API_KEY=

# St. Louis Fed Web Services / FRED API
FRED_API_KEY=
